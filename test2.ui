     <item>
      <widget class="QSlider" name="freqSlider">
       <property name="styleSheet">
        <string notr="true">/* 1. 軌道底色 (深藍灰色) */
QSlider::groove:horizontal {
    border: none;
    height: 6px; /* 軌道粗細 */
    background: #1c2e40; 
    border-radius: 3px;
}

/* 2. 手柄左側已滑過的軌道 (套用青色漸層) */
QSlider::sub-page:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #007b8f, stop:1 #00d4ff);
    border-radius: 3px;
}

/* 3. 滑動手柄本人 (白色實心圓點 + 青色邊框) */
QSlider::handle:horizontal {
    background: #ffffff;
    border: 2px solid #00d4ff;
    width: 16px;
    height: 16px;
    margin: -5px 0; /* 讓圓點上下凸出軌道 */
    border-radius: 8px; /* 變成完美圓形 */
}

/* 4. 滑鼠游標放上手柄時的變化 (反轉顏色發光) */
QSlider::handle:horizontal:hover {
    background: #00d4ff;
    border: 2px solid #ffffff;
}</string>
