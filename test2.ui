      <widget class="QPushButton" name="StartButton">
       <property name="minimumSize">
        <size>
         <width>0</width>
         <height>70</height>
        </size>
       </property>
       <property name="styleSheet">
        <string notr="true">QPushButton#StartButton {
    /* 青色漸層背景 */
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #007b8f, stop:1 #00d4ff);
    color: white;
    font-size: 26px;
    font-weight: bold;
    border-radius: 35px; /* 讓按鈕變成完美的膠囊圓角，請依據你的按鈕高度調整 (高度的一半) */
    border: 2px solid #00ffff; /* 外圍加上發光感的邊線 */
}

/* 滑鼠移過去與按下去的動態效果 */
QPushButton#StartButton:hover {
    background-color: #00ffff;
    color: #0b131e;
}
QPushButton#StartButton:pressed {
    background-color: #0099bb;
}</string>
